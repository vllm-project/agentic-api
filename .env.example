# External API keys
VR_OPENAI_API_KEY=

# Service connection (dev)
# VR_DB_PATH=postgresql+psycopg://owlpguser:owlpgpassword@localhost:5432/jamaibase_owl
# VR_OPENTELEMETRY_HOST=localhost
# VR_OPENTELEMETRY_PORT=4317
# VR_REDIS_HOST=localhost
# VR_REDIS_PORT=6379
